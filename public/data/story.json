            { "type": "battle", "trainerName": "그림자단 보스 흑염", "team": [{"monsterId": 89, "level": 44}, {"monsterId": 20, "level": 44}, {"monsterId": 64, "level": 45}, {"monsterId": 88, "level": 46}, {"monsterId": 98, "level": 48}], "reward": 8000 }
