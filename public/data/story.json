            { "type": "rival_battle" }
          ]
        },
        {
          "id": "ch3_02",
          "location": "gym_03",
          "trigger": "defeat_gym",
          "scenes": [
            {
              "type": "dialog",
              "speaker": "수호자 미나",
              "text": "물처럼 유연하면서도 강하구나. 해류의 인장을 받아라."
            },
            {
              "type": "dialog",
              "speaker": "수호자 미나",
              "text": "바다 건너편에서 마족의 기운이 점점 강해지고 있어... 서둘러야 해."
            }
          ]
        }
      ]
    },
    {
      "id": 4,
      "title": "전격의 시련",
      "events": [
        {
          "id": "ch4_01",
          "location": "route_04",
          "trigger": "arrive",
          "scenes": [
            {
              "type": "dialog",
              "speaker": "그림자단 간부 흑사",
