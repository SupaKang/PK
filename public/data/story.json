      ]
    },
    {
      "id": 6,
      "title": "빙결과 용의 시련",
      "events": [
        {
          "id": "ch6_01",
          "location": "gym_06",
          "trigger": "defeat_gym",
          "scenes": [
            {
              "type": "dialog",
              "speaker": "수호자 설화",
              "text": "차가운 바람 속에서도 꺾이지 않는구나. 빙결의 인장이다."
            },
            {
              "type": "dialog",
              "speaker": "수호자 설화",
              "text": "용왕은 모든 수호자 중 가장 강해. 각오해라."
            }
          ]
        },
        {
          "id": "ch6_02",
          "location": "route_07",
          "trigger": "arrive",
          "scenes": [
            {
              "type": "dialog",
              "speaker": "그림자단 간부 검은달",
              "text": "여기까지 온 건 칭찬해주지. 하지만 마왕님의 명령이다. 여기서 끝내주마!"
            },
            { "type": "battle", "trainerName": "그림자단 간부 검은달", "team": [{"monsterId": 83, "level": 38}, {"monsterId": 89, "level": 40}, {"monsterId": 64, "level": 42}], "reward": 4000 }
          ]
        },
        {
          "id": "ch6_03",
