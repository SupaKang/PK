---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const links = [
  { href: '/', label: '게임 소개' },
  { href: '/story', label: '스토리' },
  { href: '/guide', label: '시스템 가이드' },
  { href: '/creatures', label: '크리처 도감' },
];

const toolLinks = [
  { href: '/tools/team-builder', label: '팀 빌더' },
  { href: '/tools/damage-calc', label: '데미지 계산기' },
  { href: '/tools/compare', label: '크리처 비교' },
  { href: '/tools/capture-calc', label: '포획률 계산기' },
];

const isToolsActive = currentPath.startsWith('/tools');
---

<header>
  <nav
    class="sticky top-0 z-50 bg-pk-bg/80 backdrop-blur-xl border-b border-pk-border"
    aria-label="메인 네비게이션"
  >
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-14">
      <!-- Logo -->
      <a href="/" class="text-pk-accent font-pixel text-sm tracking-widest hover:opacity-80 transition-opacity" aria-label="포켓 왕국 홈">
        PK
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex gap-1 items-center" role="list">
        {links.map(link => {
          const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
          return (
            <a
              href={link.href}
              role="listitem"
              class:list={[
                'px-3 py-1.5 text-sm transition-all relative',
                isActive
                  ? 'text-pk-accent'
                  : 'text-pk-text-secondary hover:text-pk-text',
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {link.label}
              {isActive && (
                <span class="absolute bottom-0 left-3 right-3 h-0.5 bg-pk-accent rounded-full nav-indicator" />
              )}
            </a>
          );
        })}
        <!-- Tools dropdown -->
        <div class="relative group" role="listitem">
          <button
            class:list={[
              'px-3 py-1.5 text-sm transition-all relative cursor-pointer',
              isToolsActive ? 'text-pk-accent' : 'text-pk-text-secondary hover:text-pk-text',
            ]}
            style="font-family: inherit;"
            aria-haspopup="true"
          >
            도구 ▾
            {isToolsActive && (
              <span class="absolute bottom-0 left-3 right-3 h-0.5 bg-pk-accent rounded-full nav-indicator" />
            )}
          </button>
          <div class="absolute top-full right-0 mt-2 hidden group-hover:block group-focus-within:block z-50 min-w-[160px]">
            <div class="bg-pk-bg/95 backdrop-blur-xl border border-pk-border rounded-lg py-1.5 shadow-glass">
              {toolLinks.map(tool => {
                const isActive = currentPath === tool.href;
                return (
                  <a
                    href={tool.href}
                    class:list={[
                      'block px-4 py-2 text-xs transition-colors rounded-md mx-1',
                      isActive ? 'text-pk-accent bg-pk-surface' : 'text-pk-text-secondary hover:text-pk-text hover:bg-pk-surface',
                    ]}
                  >
                    {tool.label}
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile hamburger -->
      <input type="checkbox" id="nav-toggle" class="hidden peer" aria-label="메뉴 열기" />
      <label
        for="nav-toggle"
        class="md:hidden cursor-pointer p-2 text-pk-text-secondary hover:text-pk-text transition-colors"
        aria-label="메뉴 토글"
        role="button"
        tabindex="0"
      >
        <svg width="20" height="16" viewBox="0 0 20 16" fill="none" aria-hidden="true">
          <rect y="0" width="20" height="2" fill="currentColor" />
          <rect y="7" width="20" height="2" fill="currentColor" />
          <rect y="14" width="20" height="2" fill="currentColor" />
        </svg>
      </label>

      <!-- Mobile menu -->
      <div
        class="hidden peer-checked:flex flex-col absolute top-14 left-0 right-0 bg-pk-bg/95 backdrop-blur-xl border-b border-pk-border md:hidden z-40"
        role="menu"
      >
        {links.map(link => {
          const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
          return (
            <a
              href={link.href}
              role="menuitem"
              class:list={[
                'text-sm px-6 py-3.5 border-b border-pk-border/30 transition-colors',
                isActive
                  ? 'text-pk-accent bg-pk-surface'
                  : 'text-pk-text-secondary hover:text-pk-text hover:bg-pk-surface/50',
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {link.label}
            </a>
          );
        })}
        <div class="px-6 py-2 text-[10px] text-pk-muted/60 tracking-wider uppercase border-b border-pk-border/30 bg-pk-bg">도구</div>
        {toolLinks.map(tool => {
          const isActive = currentPath === tool.href;
          return (
            <a
              href={tool.href}
              role="menuitem"
              class:list={[
                'text-sm px-8 py-3 border-b border-pk-border/30 transition-colors',
                isActive
                  ? 'text-pk-accent bg-pk-surface'
                  : 'text-pk-text-secondary hover:text-pk-text hover:bg-pk-surface/50',
              ]}
            >
              {tool.label}
            </a>
          );
        })}
      </div>
    </div>
  </nav>
</header>

<style>
  .nav-indicator {
    animation: nav-slide-in 0.3s ease-out;
  }
  @keyframes nav-slide-in {
    from { transform: scaleX(0); opacity: 0; }
    to { transform: scaleX(1); opacity: 1; }
  }
</style>
