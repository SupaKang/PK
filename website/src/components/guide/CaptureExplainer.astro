---
const stones = [
  { name: '마석', mult: '1.0x', price: '200G', color: '#9999bb' },
  { name: '상급 마석', mult: '1.5x', price: '600G', color: '#3399FF' },
  { name: '최상급 마석', mult: '2.0x', price: '1200G', color: '#FFCC00' },
  { name: '지배의 마석', mult: '255x', price: '비매품', color: '#AA44CC' },
];
---

<section class="mb-12 reveal" aria-label="계약 시스템">
  <h2 class="section-title">계약(포획) 시스템</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5 reveal-children">
    <div class="pixel-card">
      <h3 class="text-sm text-pk-accent mb-4">마석 등급</h3>
      <div class="space-y-2">
        {stones.map(s => (
          <div class="flex items-center gap-3 text-xs bg-pk-bg p-2.5 border border-pk-border/20 group hover:border-pk-border/40 transition-colors">
            <span class="w-3 h-3 shrink-0 transition-shadow group-hover:shadow-[0_0_6px_currentColor]" style={`background: ${s.color}; color: ${s.color}`} aria-hidden="true"></span>
            <span class="text-pk-text flex-1">{s.name}</span>
            <span class="text-xs font-bold" style={`color: ${s.color}`}>{s.mult}</span>
            <span class="text-pk-muted text-[10px]">{s.price}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="pixel-card">
      <h3 class="text-sm text-pk-accent mb-4">포획 확률 요소</h3>
      <dl class="space-y-3 text-xs">
        <div>
          <dt class="text-pk-accent mb-0.5">HP 비율</dt>
          <dd class="text-pk-text-secondary text-[11px]">대상 몬스터의 HP가 낮을수록 포획률 상승</dd>
        </div>
        <div>
          <dt class="text-pk-accent mb-0.5">상태 이상 보너스</dt>
          <dd class="text-pk-text-secondary text-[11px]">수면/빙결 <strong class="text-pk-text">x2.5</strong> | 독/화상/마비 <strong class="text-pk-text">x1.5</strong></dd>
        </div>
        <div>
          <dt class="text-pk-accent mb-0.5">기본 포획률</dt>
          <dd class="text-pk-text-secondary text-[11px]">몬스터마다 고유 포획률 보유 (3~255)</dd>
        </div>
        <div>
          <dt class="text-pk-accent mb-0.5">4회 흔들림</dt>
          <dd class="text-pk-text-secondary text-[11px]">마석이 4번 흔들린 후 계약 성공 확정</dd>
        </div>
      </dl>
    </div>
  </div>
</section>
