---
import { items, itemCategories } from '../../data/items';

const grouped = items.reduce((acc, item) => {
  if (!acc[item.category]) acc[item.category] = [];
  acc[item.category].push(item);
  return acc;
}, {} as Record<string, typeof items>);

const categoryOrder = ['healing', 'contract', 'battle', 'consumable', 'key'];
---

<section class="mb-12 reveal" aria-label="아이템 목록">
  <h2 class="section-title">아이템 목록</h2>

  {categoryOrder.filter(cat => grouped[cat]).map(cat => (
    <div class="mb-8">
      <h3 class="text-sm text-pk-accent mb-3">{itemCategories[cat] || cat}</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-xs" role="table">
          <thead>
            <tr class="border-b-2 border-pk-border/30">
              <th scope="col" class="text-left py-2 px-2 text-[10px] text-pk-muted uppercase tracking-wider">이름</th>
              <th scope="col" class="text-left py-2 px-2 text-[10px] text-pk-muted uppercase tracking-wider hidden sm:table-cell">설명</th>
              <th scope="col" class="text-right py-2 px-2 text-[10px] text-pk-muted uppercase tracking-wider">가격</th>
            </tr>
          </thead>
          <tbody>
            {grouped[cat].map(item => (
              <tr class="border-b border-pk-border/10 hover:bg-pk-surface/30 transition-colors">
                <td class="py-2 px-2 text-pk-text">{item.name}</td>
                <td class="py-2 px-2 text-pk-muted hidden sm:table-cell">{item.description}</td>
                <td class="py-2 px-2 text-right text-pk-accent">
                  {item.price > 0 ? `${item.price}G` : '—'}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  ))}
</section>
