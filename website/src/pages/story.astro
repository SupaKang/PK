---
import BaseLayout from '../layouts/BaseLayout.astro';
import TableOfContents from '../components/layout/TableOfContents.astro';
import ChapterTimeline from '../components/story/ChapterTimeline.astro';
import CharacterCards from '../components/story/CharacterCards.astro';
import KarmaSystem from '../components/story/KarmaSystem.astro';
import EndingsSection from '../components/story/EndingsSection.astro';
import WorldMap from '../components/story/WorldMap.astro';
import WorldMapInteractive from '../components/story/WorldMapInteractive.tsx';
import { maps } from '../data/maps';

const tocItems = [
  { id: 'characters', label: '주요 인물' },
  { id: 'chapters', label: '10장의 여정' },
  { id: 'karma', label: '카르마 시스템' },
  { id: 'endings', label: '세 가지 엔딩' },
  { id: 'world-map', label: '월드맵' },
];
---

<BaseLayout title="스토리 & 세계관 — 포켓 왕국">
  <section class="relative py-20 px-4 text-center overflow-hidden" aria-label="스토리 헤더">
    <div class="absolute inset-0 bg-gradient-to-b from-[#1a1030] via-[#150e25] to-pk-bg" aria-hidden="true"></div>
    <!-- Decorative scroll ornaments -->
    <div class="absolute top-6 left-1/2 -translate-x-1/2 text-pk-accent/10 text-6xl select-none pointer-events-none animate-fade-up" aria-hidden="true">
      ❧
    </div>
    <div class="absolute bottom-4 left-8 text-[#AA44CC]/8 text-3xl select-none pointer-events-none" aria-hidden="true">✦</div>
    <div class="absolute top-12 right-8 text-[#3399FF]/8 text-2xl select-none pointer-events-none" aria-hidden="true">◆</div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <p class="text-[#AA88CC] text-xs tracking-[0.3em] uppercase mb-4 animate-fade-up">STORY & WORLD</p>
      <h1 class="text-pk-accent animate-fade-up-delay-1 mb-4">
        스토리 & 세계관
      </h1>
      <p class="text-pk-text-secondary text-sm animate-fade-up-delay-2 text-balance">
        어둠에 물든 세계를 되찾는 계약자의 여정
      </p>
      <div class="mt-6 flex justify-center gap-2 animate-fade-up-delay-3" aria-hidden="true">
        <span class="w-2 h-2 bg-[#FF4422]/40"></span>
        <span class="w-8 h-2 bg-pk-accent/30"></span>
        <span class="w-2 h-2 bg-[#3399FF]/40"></span>
      </div>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 py-12">
    <TableOfContents items={tocItems} />
    <div id="characters"><CharacterCards /></div>
    <div class="pixel-divider" aria-hidden="true"></div>
    <div id="chapters"><ChapterTimeline /></div>
    <div class="pixel-divider" aria-hidden="true"></div>
    <div id="karma"><KarmaSystem /></div>
    <div id="endings"><EndingsSection /></div>
    <div class="pixel-divider" aria-hidden="true"></div>
    <div id="world-map">
      <section class="mb-12 reveal" aria-label="인터랙티브 월드맵">
        <h2 class="section-title">월드맵</h2>
        <p class="text-sm text-pk-text-secondary mb-6">
          노드를 클릭하면 상세 정보를 확인할 수 있습니다.
        </p>
        <WorldMapInteractive maps={maps} client:visible />
      </section>
    </div>
  </div>
</BaseLayout>
