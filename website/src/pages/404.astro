---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — 포켓 왕국">
  <section class="relative min-h-[70vh] flex flex-col items-center justify-center text-center px-4">
    <div class="absolute inset-0 bg-gradient-to-b from-[#1a1020] via-pk-bg to-pk-bg" aria-hidden="true"></div>

    <div class="relative z-10 max-w-lg mx-auto">
      <!-- Large 404 -->
      <p class="text-7xl md:text-9xl text-pk-accent font-bold mb-6 animate-fade-up" style="
        text-shadow: 0 0 40px rgba(240,192,64,0.15);
      ">
        404
      </p>

      <!-- Escaped creature silhouette -->
      <div class="mb-8 animate-fade-up-delay-1">
        <div
          class="w-16 h-16 mx-auto opacity-30 animate-float"
          style="
            background: linear-gradient(145deg, #666688, #3a3a5c);
            clip-path: polygon(20% 85%, 25% 35%, 40% 15%, 60% 15%, 75% 35%, 80% 85%, 65% 95%, 35% 95%);
            filter: drop-shadow(0 4px 8px rgba(0,0,0,0.5));
          "
          aria-hidden="true"
        ></div>
      </div>

      <h1 class="text-lg text-pk-text mb-3 animate-fade-up-delay-2">
        이 크리처는 야생에서 도망갔습니다...
      </h1>
      <p class="text-sm text-pk-muted mb-10 animate-fade-up-delay-3">
        찾으시는 페이지가 존재하지 않거나 이동되었습니다.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-up-delay-4">
        <a href="/" class="pixel-btn">
          홈으로 돌아가기
        </a>
        <a href="/creatures" class="pixel-btn-ghost">
          크리처 도감 보기
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
